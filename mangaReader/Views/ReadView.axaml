<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:mangaReader.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="mangaReader.Views.ReadView"
             x:DataType="vm:ReadViewModel">

    <Grid RowDefinitions="*">
        <ScrollViewer>
            <StackPanel Margin="20" Spacing="20">
                <TextBlock Text="Lista de leitura" FontSize="28" FontWeight="Bold" Foreground="#2E2E2E"/>
                
                <StackPanel Spacing="10">
                    <ItemsControl ItemsSource="{Binding ReadMangaList}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="10" Padding="15" Background="#F5F5F5" CornerRadius="8" 
                                        BorderBrush="#E0E0E0" BorderThickness="1" Width="280">
                                    <StackPanel Spacing="10">
                                        <Border Height="200" Background="#E0E0E0" CornerRadius="4">
                                            <TextBlock Text="[Cover Image]" VerticalAlignment="Center" 
                                                       HorizontalAlignment="Center" Foreground="#757575"/>
                                        </Border>
                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" 
                                                   TextWrapping="Wrap" Foreground="#2E2E2E"/>
                                        <TextBlock Text="{Binding Author}" FontSize="12" Foreground="#616161"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" TextWrapping="Wrap" 
                                                   Foreground="#757575" MaxHeight="60"/>
                                        <StackPanel Orientation="Horizontal" Spacing="15">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Capítulos" FontSize="11" Foreground="#757575"/>
                                                <TextBlock Text="{Binding ChaptersCount}" FontSize="14" FontWeight="Bold" 
                                                           Foreground="#1976D2"/>
                                            </StackPanel>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Status" FontSize="11" Foreground="#757575"/>
                                                <TextBlock Text="{Binding Status}" FontSize="12" Foreground="#558B2F"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Content="Continuar lendo" HorizontalContentAlignment="Center" 
                                                Background="#558B2F" Foreground="White" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
